{
  "name": "agentforge",
  "version": "6.5.0",
  "description": "Adaptive Agent Team Builder for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server/main.js",
    "dev": "tsc --watch & node --watch dist/server/main.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "sprint": "npx tsx scripts/run-sprint.ts",
    "reports": "npm run build && node dist/scripts/run-reports.js",
    "dashboard": "npx serve . -l 3000",
    "docs": "npx typedoc --out docs/api src/index.ts --plugin none",
    "v5:build": "bash scripts/build-v5.sh",
    "v5:check": "bash scripts/check-v5.sh",
    "v5:start": "node packages/server/dist/main.js",
    "v5:dev": "concurrently --names \"server,dash\" --prefix-colors \"blue,green\" \"npm run v5:server\" \"npm run v5:dash\"",
    "v5:server": "node --watch packages/server/dist/main.js",
    "v5:dash": "cd packages/dashboard && npx vite --port 4751",
    "v5:server:dev": "cd packages/server && node --watch dist/main.js",
    "v5:dash:dev": "cd packages/dashboard && npx vite dev --port 4751",
    "autonomous:cycle": "node packages/cli/dist/bin.js autonomous:cycle"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.1.0",
    "fastify": "^5.8.4",
    "js-yaml": "^4.1.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
