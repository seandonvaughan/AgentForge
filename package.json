{
  "name": "agentforge",
  "version": "10.5.1",
  "description": "Adaptive Agent Team Builder for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@sveltejs/kit>cookie": "^0.7.0",
      "postcss": "8.5.12",
      "protobufjs": "^7.5.8",
      "vite": "8.0.13",
      "fast-uri": ">=3.1.2",
      "svelte": ">=5.55.7",
      "ws": "^8.20.1",
      "brace-expansion": "^5.0.6"
    }
  },
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "check:types": "tsc -b",
    "start": "npm run build && node packages/server/dist/main.js",
    "dev": "npm run build && concurrently --names \"build,server,dash\" --prefix-colors \"yellow,blue,green\" \"tsc -b --watch\" \"node --watch packages/server/dist/main.js\" \"cd packages/dashboard && npx vite dev --port 4751\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:dashboard": "playwright test tests/e2e/dashboard-agents.test.ts tests/e2e/dashboard-runner.test.ts tests/e2e/dashboard-live.test.ts tests/e2e/dashboard-health.test.ts tests/e2e/dashboard-org.test.ts tests/e2e/dashboard-cycle-launch.test.ts tests/e2e/dashboard-cycle-detail.test.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint \"src/**/*.{js,mjs,cjs,ts,tsx}\" \"packages/**/*.{js,mjs,cjs,ts,tsx,svelte}\" \"tests/**/*.{js,mjs,cjs,ts,tsx}\" \"scripts/**/*.{js,mjs,cjs,ts,tsx}\" \"*.config.{js,mjs,cjs,ts,tsx}\" eslint.config.js --max-warnings=0",
    "check:versions": "node scripts/check-version-sync.mjs",
    "check:help": "node scripts/check-help-output.mjs",
    "check:changelog": "node scripts/check-changelog.mjs",
    "dashboard:check": "corepack pnpm --filter @agentforge/dashboard check",
    "dashboard:build": "corepack pnpm --filter @agentforge/dashboard build",
    "audit:prod": "corepack pnpm audit --prod --audit-level low",
    "audit:all": "corepack pnpm audit --audit-level low",
    "audit:deps": "corepack pnpm audit --audit-level low",
    "sbom": "node scripts/generate-sbom.mjs",
    "sbom:ci": "node scripts/generate-sbom.mjs artifacts/sbom/cyclonedx.json",
    "verify:dashboard": "corepack pnpm dashboard:check && corepack pnpm dashboard:build",
    "verify:product": "corepack pnpm check:types && corepack pnpm test:run && corepack pnpm test:e2e:dashboard",
    "verify:gates": "corepack pnpm lint && corepack pnpm check:versions && corepack pnpm verify:product && corepack pnpm verify:dashboard && corepack pnpm check:help && corepack pnpm check:changelog && corepack pnpm audit:deps",
    "sprint": "npx tsx scripts/run-sprint.ts",
    "reports": "npx tsx scripts/run-reports.ts",
    "docs": "npx typedoc --out docs/api src/index.ts --plugin none",
    "v5:build": "bash scripts/build-v5.sh",
    "v5:check": "bash scripts/check-v5.sh",
    "v5:start": "node packages/server/dist/main.js",
    "v5:dev": "concurrently --names \"server,dash\" --prefix-colors \"blue,green\" \"npm run v5:server\" \"npm run v5:dash\"",
    "v5:server": "node --watch packages/server/dist/main.js",
    "v5:dash": "cd packages/dashboard && npx vite --port 4751",
    "v5:server:dev": "cd packages/server && node --watch dist/main.js",
    "v5:dash:dev": "cd packages/dashboard && npx vite dev --port 4751",
    "autonomous:cycle": "node packages/cli/dist/bin.js autonomous:cycle"
  },
  "dependencies": {
    "@agentforge/core": "workspace:*",
    "@agentforge/server": "workspace:*",
    "@anthropic-ai/sdk": "^0.95.2",
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/binding-darwin-arm64": "^1.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "concurrently": "^9.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
