{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/core" },
    { "path": "packages/db" },
    { "path": "packages/server" },
    { "path": "packages/embeddings" },
    { "path": "packages/plugins-sdk" },
    { "path": "packages/cli" },
    { "path": "packages/executor" }
  ]
}
