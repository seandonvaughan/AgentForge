{
  "name": "@agentforge/core",
  "version": "10.5.1",
  "description": "AgentForge package-canonical runtime, orchestration, and team services",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentforge/db": "workspace:*",
    "@agentforge/embeddings": "workspace:*",
    "@agentforge/shared": "workspace:*",
    "@agentforge/skills-catalog": "workspace:*",
    "@anthropic-ai/sdk": "^0.104.1",
    "js-yaml": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
